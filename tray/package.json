{
  "name": "clawd-tray",
  "version": "1.0.0",
  "description": "Agente Windows para o sistema claude-tg-tmux — expõe browser, tela, câmera e clipboard ao clawd",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "build": "node build.js",
    "install-browser": "npx playwright install chromium"
  },
  "pkg": {
    "scripts": "index.js",
    "assets": ["icon.ico"],
    "outputPath": "dist",
    "targets": ["node18-win-x64"]
  },
  "dependencies": {
    "node-notifier": "^10.0.1",
    "playwright-core": "^1.50.0",
    "screenshot-desktop": "^1.15.3",
    "systray2": "^2.1.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.11.0",
    "rcedit": "^4.0.1"
  }
}
