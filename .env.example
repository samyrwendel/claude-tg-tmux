# claude-tg-tmux — configuração principal
# Copie para .env e preencha os valores

# Telegram Bot (@mainagentebot)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Usuários permitidos (comma-separated user IDs)
ALLOWED_USER_IDS=123456789
ADMIN_CHAT_ID=123456789

# ElevenLabs TTS (opcional)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# OpenAI (para STT via Whisper API — opcional)
OPENAI_API_KEY=

# BigQuery logging (opcional)
BQ_ENABLED=false
BQ_LOG_SCRIPT=

# Workspace e Google Cloud (para BigQuery RAG)
WORKSPACE=/home/clawd
GOOGLE_APPLICATION_CREDENTIALS=/home/clawd/.config/gcloud/service-account.json

# Sessão tmux (padrão: mainbot)
SESSION_NAME=mainbot

# Clawd Tray — gateway WebSocket para o PC do Samyr
TRAY_PORT=18791
TRAY_PASSWORD=senha_forte_aqui
