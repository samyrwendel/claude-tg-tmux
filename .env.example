# claude-tg-tmux — configuração principal
# Copie para .env e preencha os valores

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Token gerado pelo @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# IDs Telegram autorizados a usar o bot (separados por vírgula)
ALLOWED_USER_IDS=123456789
# Chat para alertas de falha (padrão: primeiro da lista acima)
ADMIN_CHAT_ID=123456789

# ── TTS — ElevenLabs (opcional) ───────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
TTS_ENABLED=true

# ── STT — Whisper API (opcional) ──────────────────────────────────────────────
OPENAI_API_KEY=

# ── BigQuery logging (opcional) ───────────────────────────────────────────────
BQ_ENABLED=false
BQ_LOG_SCRIPT=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Workspace ─────────────────────────────────────────────────────────────────
# Diretório de trabalho do Claude (padrão: home do usuário)
WORKSPACE=

# ── tmux ──────────────────────────────────────────────────────────────────────
SESSION_NAME=mainbot

# ── ClaudeNode Tray — gateway WebSocket ───────────────────────────────────────
# Porta do gateway (Windows conecta nessa porta)
TRAY_PORT=18791
# Senha de autenticação do gateway (mude para algo forte)
TRAY_PASSWORD=

# ── Watchdog ──────────────────────────────────────────────────────────────────
# Caminho do binário claude (deixe em branco para autodetectar via PATH)
CLAUDE_BIN=
# Canal do plugin Telegram
CLAUDE_CHANNEL=plugin:telegram@claude-plugins-official
# Diretório de agents do mainbot
AGENTS_DIR=~/.claude/agents/mainbot
