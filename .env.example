# ============================================================
# claude-tg-tmux — Configuração por instância
# Copie para .env e preencha os valores
# ============================================================

# === Telegram ===
TELEGRAM_BOT_TOKEN=         # Token do bot (@BotFather)
ALLOWED_USER_IDS=           # IDs separados por vírgula (ex: 30289486,99887766)
ADMIN_CHAT_ID=              # ID do chat para alertas de falha (geralmente seu user_id)

# === Claude ===
CLAUDE_BIN=/home/$USER/.npm-global/bin/claude
WORKSPACE=$HOME/workspace   # Diretório de trabalho do agente
SESSION_NAME=nanobot        # Nome da sessão tmux

# === TTS — ElevenLabs (opcional) ===
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=30D0RicpFBZ55TdpseEa
TTS_ENABLED=true            # false para desativar TTS

# === BigQuery RAG (opcional) ===
BQ_ENABLED=false
GOOGLE_APPLICATION_CREDENTIALS=  # Path para service-account.json
BQ_PROJECT_ID=
BQ_DATASET=clawdbot
BQ_LOG_SCRIPT=              # Path para log-interaction.js (opcional)
